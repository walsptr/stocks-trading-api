STOCKS_DATABASE_URL=postgresql+psycopg://stocks:stocks@localhost:5432/stocks
TZ=Asia/Jakarta
STOCKS_TIMEZONE=Asia/Jakarta
STOCKS_BATCH_SIZE=25
STOCKS_MAX_WORKERS=4
STOCKS_MAX_ATTEMPTS=3
STOCKS_RETRY_BASE_SECONDS=1.0
STOCKS_INCREMENTAL_OVERLAP_DAYS=7
STOCKS_APP_PORT=21235
STOCKS_RULES_CONFIG_PATH=config/rules-swing-v1.yaml
STOCKS_STRATEGIES_CONFIG_DIR=config/strategies
STOCKS_SCORING_CONFIG_PATH=config/scoring/swing-trend-following-v1.yaml
STOCKS_RANKING_CONFIG_PATH=config/ranking/technical-v1.yaml
STOCKS_ANALYSIS_CONFIG_PATH=config/analysis/technical-v1.yaml
STOCKS_ALERTS_CONFIG_PATH=config/alerts/technical-v1.yaml
STOCKS_BACKTEST_CONFIG_PATH=config/backtesting/swing-trend-following-v1.yaml
STOCKS_OPTIMIZATION_CONFIG_PATH=config/optimization/swing-trend-following-v1.yaml
STOCKS_RISK_CONFIG_PATH=config/risk/technical-v1.yaml
STOCKS_POSITIONS_CONFIG_PATH=config/positions/swing-lifecycle-v1.yaml
STOCKS_CORS_ORIGINS=http://localhost:21231,http://127.0.0.1:21231
STOCKS_SCHEDULER_ENABLED=true
STOCKS_SCHEDULER_TIMEZONE=Asia/Jakarta
STOCKS_SCHEDULER_HOUR=18
STOCKS_SCHEDULER_MINUTE=0
STOCKS_SYNC_BOOTSTRAP_YEARS=1
STOCKS_SYNC_POLL_SECONDS=2
STOCKS_TELEGRAM_BOT_TOKEN=
STOCKS_TELEGRAM_CHAT_ID=
STOCKS_LOG_LEVEL=INFO
